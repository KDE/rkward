"modify them. (Other assignment operations could still modify them!)"
msgstr ""
"Déan meastóireacht ar chód i raon feidhme linbh de .GlobalEnv. Is féidir "
"rochtain a fháil ar réada i .GlobalEnv, ach ní dhéanfaidh sannadh rialta ag "
"baint úsáide as an oibreoir <tt>&lt;-</tt> iad a mhodhnú. (D’fhéadfadh "
"oibríochtaí sannadh eile iad a mhodhnú fós!)"

#: rkward/windows/rkcommandeditorwindow.cpp:899
#, kde-format
msgid "Local"
msgstr "Áitiúil"

#: rkward/windows/rkcommandeditorwindow.cpp:900
#, kde-format
msgid ""
"Evaluate code in true local environment. Objects in .GlobalEnv are not on "
"the search path, and will not be modified by regular assignments using the "
"<tt>&lt;-</tt>-operator. (Other assignment operations could still modify "
"them!)"
msgstr ""
"Déan meastóireacht ar chód i dtimpeallacht áitiúil fíor. Níl réada i ."
"GlobalEnv ar an gcosán cuardaigh, agus ní dhéanfar iad a mhodhnú le sannadh "
"rialta ag baint úsáide as an oibreoir <tt>&lt;-</tt>. (D’fhéadfadh "
"oibríochtaí sannadh eile iad a mhodhnú fós!)"

