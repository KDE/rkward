#: rkward/plugins/distributions/../plots/plot_options.rkh:58
#: rkward/plugins/distributions/../plots/plot_stepfun_options.rkh:31
#, kde-format
msgid ""
"The following external tags are provided for use in the embedding plugin."
msgstr ""
"Cuirtear na clibeanna seachtracha seo a leanas ar fáil lena n-úsáid sa "
"bhreiseán leabaithe."

#. i18n: i18n: "true", "false", and terms inside <i></i> or <b></b> should not be translated, here
#. i18n: i18n: "true", "false, and terms inside <i></i> or <b></b> should not be translated, here
