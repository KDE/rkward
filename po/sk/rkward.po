#: rkward/settings/rksettingsmodulegraphics.cpp:57
#, kde-format
msgid "Platform default device"
msgstr "Predvolené zariadenie platformy"

#: rkward/settings/rksettingsmodulegraphics.cpp:59
#, kde-format
msgid ""
"<p>The default device to be used for plotting, i.e. when new plot is "
"created, while no graphics device is active (see <i>options(\"device\")</i>)."
"</p><p>The RKWard native device is the recommended choice for most users. "
"This corresponds to the R command <i>RK()</i>.</p><p>The 'Platform default "
"device' corresponds to one of <i>X11()</i>, <i>windows()</i>, or "
"<i>quartz()</i>, depending on the platform.</p><p>You can also specify the "
"name of a function such as <i>Cairo</i>.</p>"
msgstr ""
"<p>The default device to be používaný na plotting, t. j. when new plot is "
"created, while no graphics device is active (see <i>options(\"device\")</i>)."
"</p><p>The RKWard native device is the recommended choice for most users. "
"This corresponds to the R command <i>RK()</i>.</p><p>The 'Platform default "
"device' corresponds to jedna z <i>X11()</i>, <i>windows()</i>, or "
"<i>quartz()</i>, depending on the platform.</p><p>Môžete also specify the "
"name of a function ako napríklad <i>Cairo</i>.</p>"

