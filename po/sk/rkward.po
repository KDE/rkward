msgstr "Importovať zo schránky"

#: rkward/dialogs/rkimportdialog.cpp:102
#, kde-format
msgid ""
"<b>Ready to go</b><p>Click \"Finish\" to start the selected import dialog, "
"or \"Back\" to explore other options.</p>"
msgstr ""
"<b>Ready to go</b><p>Click \"Finish\" to start the vybrané import dialog, or "
"\"Back\" to explore other options.</p>"

#: rkward/dialogs/rkimportdialog.cpp:104
#, kde-format
