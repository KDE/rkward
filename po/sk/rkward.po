#, kde-format
msgid ""
"Note: Further shortcuts can be assigned, and by default, Ctrl+Space invokes "
"completions, in addition to this. Further, pressing the Tab key, while "
"completions are shown, performs partial completion (if possible), "
"independent of this setting."
msgstr ""
"Poznámka: Ďalšie skratky možno priradiť a predvolene Ctrl+Medzerník vyvolá "
"dokončenia, okrem nastavení nižšie."

#: rkward/settings/rksettingsmodulecommandeditor.cpp:77
#, kde-format
msgid "Tab key invokes code completion"
msgstr "Kláves Tab vyvolá dopĺňanie kódu"

